# 1. Importamos el conector (Framework Connector)
# En el curso usan ChatNVIDIA, tú usarás el de Google para Gemma 4
from langchain_google_genai import ChatGoogleGenerativeAI
import os

# 2. Configuramos el modelo (La "Capa de Abstracción Alta")
# Esto reemplaza la conexión al 'llm_client' de NVIDIA
llm = ChatGoogleGenerativeAI(
    model="gemma-4", 
    google_api_key=os.environ.get("GOOGLE_API_KEY")
)

# 3. Probamos la ejecución (Igual que el 'llm.invoke' del curso)
print("Enviando consulta al modelo...")
try:
    # Usamos 'stream' para ver los tokens conforme llegan, como en el curso
    for chunk in llm.stream("Hola, soy un desarrollador aprendiendo RAG. ¿Qué es un endpoint?"):
        print(chunk.content, end="", flush=True)
except Exception as e:
    print(f"Error de conexión: {e}")
